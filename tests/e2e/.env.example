# E2E test database credentials
# Copy to .env and fill in your values:
#   cp tests/e2e/.env.example tests/e2e/.env
#
# The .env file is gitignored. In CI, set these as env vars directly.

RDST_E2E_DB_HOST=localhost
RDST_E2E_DB_PORT=5432
RDST_E2E_DB_USER=rdst
RDST_E2E_DB_DATABASE=rdst
RDST_E2E_DB_ENGINE=postgresql
RDST_E2E_DB_PASSWORD=your_password_here

# ANTHROPIC_API_KEY is also required but typically already set in your shell.
